# RWAS Shopify MCP Server Environment Variables
# Copy to .env and fill in actual values from Keeper vault

# Shopify store domain (myshopify domain, NOT custom domain)
SHOPIFY_STORE_DOMAIN=rogerwilcoaviation.myshopify.com

# Admin API access token — retrieve from Keeper: keeper search "Shopify API"
# Required scopes: read_products, write_products, read_orders, write_orders,
# read_draft_orders, write_draft_orders, read_inventory, write_inventory,
# read_customers, write_customers, read_content, write_content
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Storefront API access token — from Shopify Admin > Headless channel
# Used for public product queries from the Next.js frontend
SHOPIFY_STOREFRONT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API version — use latest stable
SHOPIFY_API_VERSION=2026-01
